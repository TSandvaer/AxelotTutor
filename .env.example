# Axelot Tutor — example environment file.
# Copy to .env.local and fill in. NEVER commit .env.local.

# --- Browser-side (VITE_*) -------------------------------------------------
# URL of the Vercel Function that proxies requests to the Anthropic API.
# Defaults to /api/claude (same origin) — only override for unusual local
# setups, e.g. running `vercel dev` on a different port.
VITE_CLAUDE_API_ENDPOINT=/api/claude

# --- Server-side (Vercel Function only) ------------------------------------
# Anthropic API key. SERVER ONLY. Read by the /api/claude function from
# process.env. It must NEVER be prefixed with VITE_ and must NEVER be added
# to the browser bundle. In production, set it in the Vercel dashboard
# (Project Settings -> Environment Variables) and never check it in here.
ANTHROPIC_API_KEY=

# Optional: extra origins allowed by the /api/claude CORS handler, comma
# separated. The function already allows http://localhost:5173 and the
# deployment's own Vercel URL. Leave blank in normal use.
CLAUDE_API_EXTRA_ORIGINS=
